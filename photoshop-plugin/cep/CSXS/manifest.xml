<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0"
  ExtensionBundleId="com.wudiming.pdf2psd"
  ExtensionBundleVersion="1.0.0"
  ExtensionBundleName="PDF → PSD">

  <ExtensionList>
    <Extension Id="com.wudiming.pdf2psd.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- PS CC 2020 (v21) through PS 2026 (v27) -->
      <Host Name="PHSP" Version="21.0"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.wudiming.pdf2psd.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/bridge.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-running-insecure-content</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>PDF → PSD</Menu>
          <Geometry>
            <Size><Height>580</Height><Width>320</Width></Size>
            <MinSize><Height>480</Height><Width>280</Width></MinSize>
            <MaxSize><Height>900</Height><Width>600</Width></MaxSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./assets/icon-23.png</Icon>
            <Icon Type="Disabled">./assets/icon-23.png</Icon>
            <Icon Type="DarkNormal">./assets/icon-23.png</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
